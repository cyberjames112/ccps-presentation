# ================================================================
# CCPS 家慶佳業 - 環境變數設定範本
# 複製此檔案為 .env 並填入實際值（本地開發用）
# Railway 部署時請直接在 Railway 後台填入以下變數
# ================================================================

# ── 資料庫（Supabase PostgreSQL）──────────────────────────────
# 從 Supabase > Project Settings > Database > Connection String
# 選擇 "Transaction" pooler 並加上 ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ── Session 安全金鑰 ──────────────────────────────────────────
# 隨機產生 64 字元以上的字串，可用以下指令產生：
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long

# ── Email 通知（Resend）──────────────────────────────────────
# 從 https://resend.com/api-keys 取得
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# 報名通知收件信箱
NOTIFICATION_EMAIL=your-email@gmail.com

# ── Google Maps（選填，如有使用地圖功能）─────────────────────
# 從 Google Cloud Console 申請
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Node 環境 ─────────────────────────────────────────────────
NODE_ENV=production
